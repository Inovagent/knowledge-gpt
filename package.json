{
  "name": "knowledge-gpt",
  "version": "0.6.0",
  "description": "Chromium extension and local backend for saving information from supported sites into Notion.",
  "license": "MIT",
  "files": [
    "extension/",
    "src/",
    ".env.example",
    "README.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "start": "node src/backend/server.js",
    "dev": "node --watch src/backend/server.js",
    "check": "find src extension test -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test": "node --test"
  },
  "keywords": [
    "chrome-extension",
    "knowledge-gpt",
    "notion",
    "youtube",
    "transcript",
    "web-capture",
    "productivity"
  ],
  "dependencies": {
    "@notionhq/client": "^2.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2"
  },
  "engines": {
    "node": ">=18"
  }
}
