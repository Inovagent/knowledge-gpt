{
  "manifest_version": 3,
  "name": "Knowledge GPT",
  "version": "0.7.0",
  "key": "",
  "description": "Save information from supported sites like YouTube and Gmail into Notion or local Markdown.",
  "permissions": ["activeTab", "contextMenus", "scripting", "storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://mail.google.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "action": {
    "default_title": "Knowledge GPT settings"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": [
        "scripts/content/constants.js",
        "scripts/content/dom.js",
        "scripts/content/transcript.js",
        "scripts/content/state.js",
        "scripts/content/button.js",
        "scripts/content/index.js"
      ],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mail.google.com/*"],
      "js": [
        "scripts/content/gmail-constants.js",
        "scripts/content/gmail-dom.js",
        "scripts/content/gmail-state.js",
        "scripts/content/gmail-button.js",
        "scripts/content/gmail-index.js"
      ],
      "css": ["styles/gmail.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "pages/options/index.html"
}
